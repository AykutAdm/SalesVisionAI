<div class="row clearfix">
    <div class="col-lg-12">
        <div class="card" style="background: linear-gradient(145deg, #1e293b 0%, #1a2332 100%); border: 1px solid #334155; border-radius: 12px; box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);">
            <ul class="row profile_state list-unstyled">
                <li class="col-lg-2 col-md-4 col-6 mb-3">
                    <div class="body text-center" style="padding: 1.5rem; transition: all 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                        <i class="zmdi zmdi-view-list" style="font-size: 3rem; color: #f59e0b; text-shadow: 0 4px 8px rgba(245, 158, 11, 0.4);"></i>
                        <h4 style="color: #f1f5f9; font-weight: 700; font-size: 2rem; margin: 1rem 0 0.5rem;">@ViewBag.CategoryCount</h4>
                        <span style="color: #cbd5e1; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.5px;">Kategori Sayısı</span>
                    </div>
                </li>
                <li class="col-lg-2 col-md-4 col-6 mb-3">
                    <div class="body text-center" style="padding: 1.5rem; transition: all 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                        <i class="zmdi zmdi-collection-item" style="font-size: 3rem; color: #3b82f6; text-shadow: 0 4px 8px rgba(59, 130, 246, 0.4);"></i>
                        <h4 style="color: #f1f5f9; font-weight: 700; font-size: 2rem; margin: 1rem 0 0.5rem;">@ViewBag.ProductCount</h4>
                        <span style="color: #cbd5e1; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.5px;">Ürün Sayısı</span>
                    </div>
                </li>
                <li class="col-lg-2 col-md-4 col-6 mb-3">
                    <div class="body text-center" style="padding: 1.5rem; transition: all 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                        <i class="zmdi zmdi-accounts" style="font-size: 3rem; color: #ef4444; text-shadow: 0 4px 8px rgba(239, 68, 68, 0.4);"></i>
                        <h4 style="color: #f1f5f9; font-weight: 700; font-size: 2rem; margin: 1rem 0 0.5rem;">@ViewBag.CustomerCount</h4>
                        <span style="color: #cbd5e1; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.5px;">Müşteri Sayısı</span>
                    </div>
                </li>
                <li class="col-lg-2 col-md-4 col-6 mb-3">
                    <div class="body text-center" style="padding: 1.5rem; transition: all 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                        <i class="zmdi zmdi-shopping-cart" style="font-size: 3rem; color: #10b981; text-shadow: 0 4px 8px rgba(16, 185, 129, 0.4);"></i>
                        <h4 style="color: #f1f5f9; font-weight: 700; font-size: 2rem; margin: 1rem 0 0.5rem;">@ViewBag.OrderCount</h4>
                        <span style="color: #cbd5e1; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.5px;">Sipariş Sayısı</span>
                    </div>
                </li>
                <li class="col-lg-2 col-md-4 col-6 mb-3">
                    <div class="body text-center" style="padding: 1.5rem; transition: all 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                        <i class="zmdi zmdi-globe" style="font-size: 3rem; color: #06b6d4; text-shadow: 0 4px 8px rgba(6, 182, 212, 0.4);"></i>
                        <h4 style="color: #f1f5f9; font-weight: 700; font-size: 2rem; margin: 1rem 0 0.5rem;">@ViewBag.CountryCount</h4>
                        <span style="color: #cbd5e1; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.5px;">Ülke Sayısı</span>
                    </div>
                </li>
                <li class="col-lg-2 col-md-4 col-6 mb-3">
                    <div class="body text-center" style="padding: 1.5rem; transition: all 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                        <i class="zmdi zmdi-city" style="font-size: 3rem; color: #f59e0b; text-shadow: 0 4px 8px rgba(245, 158, 11, 0.4);"></i>
                        <h4 style="color: #f1f5f9; font-weight: 700; font-size: 2rem; margin: 1rem 0 0.5rem;">@ViewBag.CityCount</h4>
                        <span style="color: #cbd5e1; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.5px;">Şehir Sayısı</span>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</div>