@model List<Order>
@{
    ViewData["Title"] = "OrderList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="content">
    <div class="block-header">
        <div class="row align-items-center">
            <div class="col-lg-7 col-md-6 col-sm-12">
                <h2>
                    <i class="zmdi zmdi-shopping-cart"></i> Sipariş Listesi
                    <small class="text-muted d-block mt-2">Sipariş İşlemleri Sayfası</small>
                </h2>
            </div>
            <div class="col-lg-5 col-md-6 col-sm-12">
                <ul class="breadcrumb float-md-right">
                    <li class="breadcrumb-item"><a href="/Dashboard/Index"><i class="zmdi zmdi-home"></i> Ana Sayfa</a></li>
                    <li class="breadcrumb-item"><a href="javascript:void(0);">Siparişler</a></li>
                    <li class="breadcrumb-item active">Sipariş Listesi</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12">
                <div class="card">
                    <div class="body">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h5 class="mb-0"><i class="zmdi zmdi-format-list-bulleted"></i> Toplam Sipariş: <span class="badge badge-primary">@Model.Count</span></h5>
                            </div>
                            <div>
                                <a href="/Order/CreateOrder/" class="btn btn-primary">
                                    <i class="zmdi zmdi-plus"></i> Yeni Sipariş Ekle
                                </a>
                            </div>
                        </div>

                        <div class="table-container">
                            <table class="table table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th><i class="zmdi zmdi-key"></i> ID</th>
                                        <th><i class="zmdi zmdi-collection-item"></i> Ürün Adı</th>
                                        <th><i class="zmdi zmdi-account"></i> Müşteri Adı</th>
                                        <th><i class="zmdi zmdi-money"></i> Birim Fiyat</th>
                                        <th><i class="zmdi zmdi-plus-square"></i> Adet</th>
                                        <th><i class="zmdi zmdi-money-box"></i> Toplam</th>
                                        <th><i class="zmdi zmdi-card"></i> Ödeme</th>
                                        <th><i class="zmdi zmdi-check-circle"></i> Durum</th>
                                        <th><i class="zmdi zmdi-calendar"></i> Tarih</th>
                                        <th><i class="zmdi zmdi-settings"></i> İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <th>#@item.OrderId</th>
                                            <td>@item.Product.ProductName</td>
                                            <td>@item.Customer.CustomerName @item.Customer.CustomerSurname</td>
                                            <td><strong>@item.Product.UnitPrice €</strong></td>
                                            <td><span class="badge badge-info">@item.Quantity</span></td>
                                            <td><strong class="text-success">@(item.Product.UnitPrice* item.Quantity) €</strong></td>
                                            <td>@item.PaymentMethod</td>
                                            <td>@item.OrderStatus</td>
                                            <td>@item.OrderDate.ToString("dd-MMM-yyyy")</td>
                                            <td>
                                                <div class="d-flex gap-2">
                                                    <a href="/Order/UpdateOrder/@item.OrderId" class="btn btn-success btn-sm" title="Güncelle">
                                                        <i class="zmdi zmdi-edit"></i>
                                                    </a>
                                                    <a href="/Order/DeleteOrder/@item.OrderId" class="btn btn-danger btn-sm" title="Sil" onclick="return confirm('Bu siparişi silmek istediğinize emin misiniz?')">
                                                        <i class="zmdi zmdi-delete"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-3 text-center">
                            <nav aria-label="Page navigation">
                                <ul class="pagination justify-content-center">

                                    @if (ViewBag.CurrentPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="/Order/OrderList?page=@(ViewBag.CurrentPage - 1)">Önceki</a>
                                        </li>
                                    }

                                    @{
                                        int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                                        int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);

                                        if (startPage > 1)
                                        {
                                            <li class="page-item">
                                                <a class="page-link" href="/Order/OrderList?page=1">1</a>
                                            </li>
                                            if (startPage > 2)
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">...</span>
                                                </li>
                                            }
                                        }

                                        for (int i = startPage; i <= endPage; i++)
                                        {
                                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                                <a class="page-link" href="/Order/OrderList?page=@i">@i</a>
                                            </li>
                                        }

                                        if (endPage < ViewBag.TotalPages)
                                        {
                                            if (endPage < ViewBag.TotalPages - 1)
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">...</span>
                                                </li>
                                            }
                                            <li class="page-item">
                                                <a class="page-link" href="/Order/OrderList?page=@ViewBag.TotalPages">@ViewBag.TotalPages</a>
                                            </li>
                                        }
                                    }

                                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="/Order/OrderList?page=@(ViewBag.CurrentPage + 1)">Sonraki</a>
                                        </li>
                                    }

                                </ul>
                            </nav>
                        </div>


                        <div class="text-center mt-4">
                            <a href="/Order/CreateOrder/" class="btn btn-primary">Yeni Sipariş Girişi</a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



